# ─── Server ───────────────────────────────────────────────────────────────────
PORT=5000
NODE_ENV=development
CLIENT_URL=http://localhost:5173

# ─── MongoDB ──────────────────────────────────────────────────────────────────
MONGO_URI=
# ─── JWT ──────────────────────────────────────────────────────────────────────
# Access token (short-lived – stored in memory/localStorage on the client)
JWT_SECRET=replace_with_a_long_random_access_secret
JWT_ACCESS_EXPIRES_IN=15m

# Refresh token (long-lived – stored in httpOnly cookie + hashed in DB)
JWT_REFRESH_SECRET=replace_with_a_different_long_random_refresh_secret
JWT_REFRESH_EXPIRES_IN_SHORT=1d        # when rememberMe = false
JWT_REFRESH_EXPIRES_IN_LONG=30d        # when rememberMe = true

# ─── Bcrypt ───────────────────────────────────────────────────────────────────
BCRYPT_SALT_ROUNDS=10

# ─── Cloudinary ───────────────────────────────────────────────────────────────
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# ─── Email (Nodemailer) ───────────────────────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password
EMAIL_FROM=PrepAI <no-reply@prepai.com>

# ─── Google Gemini AI ─────────────────────────────────────────────────────────
GEMINI_API_KEY=
GEMINI_MODEL=gemini-1.5-flash

# ─── Rate Limiting ────────────────────────────────────────────────────────────
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=200
